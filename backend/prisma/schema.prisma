generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Goal {
  bulking
  cutting
  maintaining
}

enum TrainingContext {
  home
  gym
}

enum Units {
  kg
  lb
}

// Detected from logged sessions (never self-declared) — PROJECT.md §1.3
enum AbilityLevel {
  beginner
  intermediate
  advanced
}

enum ExerciseCategory {
  bodybuilding
  powerlifting
  crossfit
  cardio
}

// Movement-pattern taxonomy (Piece 1): the axis progression ladders run on.
enum MovementPattern {
  squat
  hinge
  push
  pull
  core
  carry
  cardio
  balance
}

model Exercise {
  id                 String           @id // stable slug, referenced by device SQLite
  name               String
  category           ExerciseCategory
  primaryMuscles     String[]         @map("primary_muscles")
  secondaryMuscles   String[]         @map("secondary_muscles")
  equipment          String[]
  demoUrl            String           @map("demo_url")
  instructions       String[]
  homeAlternativeId  String?          @map("home_alternative_id")
  homeAlternative    Exercise?        @relation("HomeAlternative", fields: [homeAlternativeId], references: [id])
  homeAlternativeFor Exercise[]       @relation("HomeAlternative")
  // Progression ladder (Piece 1): pattern + tier (1 low – 4 high) and soft
  // links to the sibling one tier down/up in the same pattern. Soft String
  // refs (like plan_id on sessions) — integrity enforced by seed + tests.
  movementPattern    MovementPattern? @map("movement_pattern")
  difficultyTier     Int?             @map("difficulty_tier")
  easierVariantId    String?          @map("easier_variant_id")
  harderVariantId    String?          @map("harder_variant_id")
  planExercises      PlanExercise[]
  sessionExercises   WorkoutSessionExercise[]
  userWorkoutExercises UserWorkoutExercise[]
  updatedAt          DateTime         @updatedAt @map("updated_at")

  @@map("exercises")
}

// User-created workout (Group F): a shareable template. Public ones appear in
// the community library for any authenticated user to copy into their plans.
model UserWorkout {
  id         String                @id @default(uuid())
  userId     String                @map("user_id")
  user       User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  name       String
  isPublic   Boolean               @default(false) @map("is_public")
  // Optional cover: a data URI or URL. Stored inline (MVP — see DECISIONS).
  coverImage String?               @map("cover_image")
  exercises  UserWorkoutExercise[]
  createdAt  DateTime              @default(now()) @map("created_at")
  updatedAt  DateTime              @updatedAt @map("updated_at")

  @@index([isPublic, createdAt])
  @@map("user_workouts")
}

model UserWorkoutExercise {
  id              String      @id @default(uuid())
  workoutId       String      @map("workout_id")
  workout         UserWorkout @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  order           Int
  exerciseId      String      @map("exercise_id")
  exercise        Exercise    @relation(fields: [exerciseId], references: [id])
  sets            Int
  reps            String
  restSeconds     Int         @map("rest_seconds")
  durationSeconds Int?        @map("duration_seconds")

  @@unique([workoutId, order])
  @@map("user_workout_exercises")
}

model User {
  id             String          @id @default(uuid())
  email          String          @unique
  passwordHash   String          @map("password_hash")
  displayName    String          @map("display_name")
  goal           Goal            @default(maintaining)
  trainingDays   Int             @default(3) @map("training_days")
  defaultContext TrainingContext @default(gym) @map("default_context")
  units          Units           @default(kg)
  abilityLevel   AbilityLevel?   @map("ability_level")
  // Public profile (Group G): surfaced ONLY via a public workout the user
  // shared; a user with no public workouts stays undiscoverable.
  avatar         String?         // data URI or URL
  publicBio      String?         @map("public_bio")
  // First-run onboarding (Piece 2): set when completed OR skipped, so the
  // wizard shows once per account (not per device). Revisitable from Profile.
  onboardedAt    DateTime?       @map("onboarded_at")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")
  plans          Plan[]
  sessions       WorkoutSession[]
  bodyweights    BodyweightEntry[]
  mealProfile    MealProfileItem[]
  mealLogs       MealLog[]
  chatMessages   ChatMessage[]
  checkins       RecoveryCheckin[]
  userWorkouts   UserWorkout[]

  @@map("users")
}

enum ChatRole {
  user
  assistant
}

// AI chat companion history — server-owned (chat requires connectivity),
// cached on device for offline reading.
model ChatMessage {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      ChatRole
  content   String
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId, createdAt])
  @@map("chat_messages")
}

enum MealType {
  breakfast
  lunch
  dinner
  snack
}

// The user's meal profile: what they ALREADY eat (PROJECT.md §1.7 — no
// prescribed meal plans). Offline-first, client UUID ids, idempotent sync.
model MealProfileItem {
  id             String    @id
  userId         String    @map("user_id")
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name           String
  typicalPortion String    @map("typical_portion")
  deletedAt      DateTime? @map("deleted_at")

  @@index([userId])
  @@map("meal_profile_items")
}

// Daily meal log; offline-first, client UUID ids, idempotent sync.
model MealLog {
  id       String   @id
  userId   String   @map("user_id")
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name     String
  portion  String
  mealType MealType @map("meal_type")
  loggedAt DateTime @map("logged_at")
  // Macros (Group B): each null when unknown; grams for the three, kcal for
  // calories. estimatedFields lists which values are AI-estimated rather than
  // user-entered, so the UI can distinguish them honestly.
  proteinG        Float?   @map("protein_g")
  carbsG          Float?   @map("carbs_g")
  fatG            Float?   @map("fat_g")
  calories        Float?
  estimatedFields String[] @map("estimated_fields")

  @@index([userId, loggedAt])
  @@map("meal_logs")
}

// Soreness/sleep check-ins feeding deload logic (PROJECT.md §1.9 — a plan
// that never deloads breaks people). Offline-first, client UUIDs.
model RecoveryCheckin {
  id           String   @id
  userId       String   @map("user_id")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  soreness     Int // 1 (fresh) – 5 (wrecked)
  sleepQuality Int      @map("sleep_quality") // 1 (awful) – 5 (great)
  loggedAt     DateTime @map("logged_at")

  @@index([userId, loggedAt])
  @@map("recovery_checkins")
}

// Offline-first bodyweight log; client-generated UUID ids, idempotent sync.
model BodyweightEntry {
  id       String   @id
  userId   String   @map("user_id")
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  weightKg Float    @map("weight_kg")
  loggedAt DateTime @map("logged_at")

  @@index([userId, loggedAt])
  @@map("bodyweight_entries")
}

// Written on-device first, synced up in batches. Ids are client-generated
// UUIDs so the sync is idempotent: re-sending a session upserts, never dupes.
model WorkoutSession {
  id              String                   @id
  userId          String                   @map("user_id")
  user            User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  planId          String?                  @map("plan_id")
  planDayId       String?                  @map("plan_day_id")
  dayName         String                   @map("day_name")
  category        ExerciseCategory
  context         TrainingContext
  startedAt       DateTime                 @map("started_at")
  finishedAt      DateTime                 @map("finished_at")
  durationSeconds Int                      @map("duration_seconds")
  /// SessionDelta JSON — the planned-vs-actual summary the AI layer reads
  delta           Json
  exercises       WorkoutSessionExercise[]
  createdAt       DateTime                 @default(now()) @map("created_at")
  updatedAt       DateTime                 @updatedAt @map("updated_at")

  @@index([userId, startedAt])
  @@map("workout_sessions")
}

model WorkoutSessionExercise {
  id                String         @id // client-generated UUID
  sessionId         String         @map("session_id")
  session           WorkoutSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  order             Int
  plannedExerciseId String?        @map("planned_exercise_id")
  actualExerciseId  String         @map("actual_exercise_id")
  actualExercise    Exercise       @relation(fields: [actualExerciseId], references: [id])
  skipped           Boolean
  sets              WorkoutSet[]

  @@unique([sessionId, order])
  @@map("workout_session_exercises")
}

model WorkoutSet {
  id                String                 @id // client-generated UUID
  sessionExerciseId String                 @map("session_exercise_id")
  sessionExercise   WorkoutSessionExercise @relation(fields: [sessionExerciseId], references: [id], onDelete: Cascade)
  setIndex          Int                    @map("set_index")
  plannedReps       String?                @map("planned_reps")
  plannedWeightKg   Float?                 @map("planned_weight_kg") // AI-prescribed load (Phase 6)
  actualReps        Int?                   @map("actual_reps")
  weightKg          Float?                 @map("weight_kg") // canonical kg; client converts
  completed         Boolean

  @@unique([sessionExerciseId, setIndex])
  @@map("workout_sets")
}

model Plan {
  id        String          @id @default(uuid())
  userId    String          @map("user_id")
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  context   TrainingContext
  isActive  Boolean         @default(true) @map("is_active")
  isCustom  Boolean         @default(false) @map("is_custom")
  // Custom-workout timer settings (Group D). Null on template plans.
  defaultRestSeconds  Int?    @map("default_rest_seconds")
  workIntervalSeconds Int?    @map("work_interval_seconds")
  autoAdvanceTimers   Boolean @default(true) @map("auto_advance_timers")
  days      PlanDay[]
  createdAt DateTime        @default(now()) @map("created_at")
  updatedAt DateTime        @updatedAt @map("updated_at")

  @@map("plans")
}

model PlanDay {
  id        String           @id @default(uuid())
  planId    String           @map("plan_id")
  plan      Plan             @relation(fields: [planId], references: [id], onDelete: Cascade)
  dayIndex  Int              @map("day_index")
  name      String
  category  ExerciseCategory
  // Mandatory daily routine (Group E): shown on Home every day, separate from
  // the day-specific split. Completing it is its own workout session.
  isDaily   Boolean          @default(false) @map("is_daily")
  exercises PlanExercise[]

  @@unique([planId, dayIndex])
  @@map("plan_days")
}

model PlanExercise {
  id          String   @id @default(uuid())
  planDayId   String   @map("plan_day_id")
  planDay     PlanDay  @relation(fields: [planDayId], references: [id], onDelete: Cascade)
  order           Int
  exerciseId      String   @map("exercise_id")
  exercise        Exercise @relation(fields: [exerciseId], references: [id])
  sets            Int
  reps            String // "8-12", "5", "20-30 min", "AMRAP 12 min" — modality-flexible
  restSeconds     Int      @map("rest_seconds")
  // Time-based exercises (holds, intervals) carry a per-set duration; null for
  // rep-based work. (Group D)
  durationSeconds Int?     @map("duration_seconds")
  // Short per-exercise cue (Piece 1 templates, e.g. "Stop if a joint hurts").
  note            String?

  @@unique([planDayId, order])
  @@map("plan_exercises")
}
