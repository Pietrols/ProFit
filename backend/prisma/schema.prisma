generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Goal {
  bulking
  cutting
  maintaining
}

enum TrainingContext {
  home
  gym
}

enum Units {
  kg
  lb
}

enum ExerciseCategory {
  bodybuilding
  powerlifting
  crossfit
  cardio
}

model Exercise {
  id                 String           @id // stable slug, referenced by device SQLite
  name               String
  category           ExerciseCategory
  primaryMuscles     String[]         @map("primary_muscles")
  secondaryMuscles   String[]         @map("secondary_muscles")
  equipment          String[]
  demoUrl            String           @map("demo_url")
  instructions       String[]
  homeAlternativeId  String?          @map("home_alternative_id")
  homeAlternative    Exercise?        @relation("HomeAlternative", fields: [homeAlternativeId], references: [id])
  homeAlternativeFor Exercise[]       @relation("HomeAlternative")
  planExercises      PlanExercise[]
  updatedAt          DateTime         @updatedAt @map("updated_at")

  @@map("exercises")
}

model User {
  id             String          @id @default(uuid())
  email          String          @unique
  passwordHash   String          @map("password_hash")
  displayName    String          @map("display_name")
  goal           Goal            @default(maintaining)
  trainingDays   Int             @default(3) @map("training_days")
  defaultContext TrainingContext @default(gym) @map("default_context")
  units          Units           @default(kg)
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")
  plans          Plan[]

  @@map("users")
}

model Plan {
  id        String          @id @default(uuid())
  userId    String          @map("user_id")
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  context   TrainingContext
  isActive  Boolean         @default(true) @map("is_active")
  days      PlanDay[]
  createdAt DateTime        @default(now()) @map("created_at")
  updatedAt DateTime        @updatedAt @map("updated_at")

  @@map("plans")
}

model PlanDay {
  id        String           @id @default(uuid())
  planId    String           @map("plan_id")
  plan      Plan             @relation(fields: [planId], references: [id], onDelete: Cascade)
  dayIndex  Int              @map("day_index")
  name      String
  category  ExerciseCategory
  exercises PlanExercise[]

  @@unique([planId, dayIndex])
  @@map("plan_days")
}

model PlanExercise {
  id          String   @id @default(uuid())
  planDayId   String   @map("plan_day_id")
  planDay     PlanDay  @relation(fields: [planDayId], references: [id], onDelete: Cascade)
  order       Int
  exerciseId  String   @map("exercise_id")
  exercise    Exercise @relation(fields: [exerciseId], references: [id])
  sets        Int
  reps        String // "8-12", "5", "20-30 min", "AMRAP 12 min" — modality-flexible
  restSeconds Int      @map("rest_seconds")

  @@unique([planDayId, order])
  @@map("plan_exercises")
}
