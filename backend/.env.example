# Copy to .env and fill in values.
# Port 5434: Postgres.app shadows 5433 on loopback (see docker-compose.yml).
DATABASE_URL="postgresql://profit:profit_dev_pass@localhost:5434/profit?sslmode=disable"
JWT_SECRET="change-me"
PORT=4000

# AI layer (Phase 6): flag + key live server-side only.
AI_ENABLED=false
ANTHROPIC_API_KEY=
AI_MODEL=claude-opus-4-8

# Transport hardening (AUDIT S4/S7)
# Comma-separated browser origins allowed by CORS; empty = browsers denied
# (native apps unaffected). Production runs behind a TLS-terminating proxy.
CORS_ORIGINS=
